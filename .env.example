# ─────────────────────────────────────────────────────────────────
# .env.example — RSProyecto Texpro
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────────────

# Servidor
PORT=3000

# Base de datos MySQL (bdtexpro)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bdtexpro

# Base de datos Softland (SQL Server) — solo lectura
SOFTLAND_DB_HOST=
SOFTLAND_DB_PORT=1433
SOFTLAND_DB_USER=
SOFTLAND_DB_PASSWORD=
SOFTLAND_DB_NAME=

# JWT
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_48_CHARS
JWT_EXPIRES_IN=8h
