# ── Servidor ─────────────────────────────────────────────
PORT=3000

# ── Base de datos MySQL (bdtexpro) ───────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=bdtexpro

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_minimo_32_chars
JWT_EXPIRES_IN=8h

# ── Correo SMTP (recuperación de contraseña) ─────────────
# Gmail (App Password recomendado):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_SECURE=false
# Outlook / Office 365:
#   MAIL_HOST=smtp.office365.com
#   MAIL_PORT=587
#   MAIL_SECURE=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=correo@texpro.cl
MAIL_PASS=tu_app_password
MAIL_FROM="TEXPRO" <correo@texpro.cl>

# ── Softland SQL Server (opcional) ───────────────────────
SOFTLAND_SERVER=
SOFTLAND_DATABASE=
SOFTLAND_USER=
SOFTLAND_PASSWORD=
