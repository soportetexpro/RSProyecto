# =============================================================
# .env.example — RSProyecto Texpro
# ─────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Reemplaza cada **** con el valor real
#   3. NUNCA commitees el archivo .env — está en .gitignore
# =============================================================

# ─────────────────────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# BASE DE DATOS LOCAL — MySQL (bdtexpro)
# Usuario dedicado recomendado: NO usar root en producción
# Crear con:
#   CREATE USER 'texpro_app'@'localhost' IDENTIFIED BY '****';
#   GRANT SELECT, INSERT, UPDATE, DELETE ON bdtexpro.* TO 'texpro_app'@'localhost';
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bdtexpro
DB_USER=****
DB_PASSWORD=****

# ─────────────────────────────────────────────────────────────
# SOFTLAND CLOUD — SQL Server (réplica de lectura)
# Driver: mssql (npm install mssql)
# Puerto por defecto SQL Server: 1433
# ─────────────────────────────────────────────────────────────
SOFTLAND_DB_HOST=****
SOFTLAND_DB_PORT=1433
SOFTLAND_DB_USER=****
SOFTLAND_DB_PASSWORD=****
SOFTLAND_DB_NAME=****
