# ── Servidor ─────────────────────────────────────────────
PORT=3000

# ── Base de datos MySQL (bdtexpro) ───────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=bdtexpro

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_minimo_32_chars
JWT_EXPIRES_IN=8h

# ── Correo — Microsoft Graph API (Office 365) ────────────
# No requiere SMTP AUTH. Usar con Application permission: Mail.Send
# Obtener en: portal.azure.com → Azure Active Directory → App registrations
MAIL_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MAIL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MAIL_CLIENT_SECRET=tu_client_secret_de_azure
MAIL_FROM_ADDRESS=soporte@texpro.cl
MAIL_FROM_NAME=TEXPRO

# ── Softland SQL Server ───────────────────────────────────
# Estas variables deben coincidir exactamente con src/config/db.softland.js
SOFTLAND_DB_HOST=
SOFTLAND_DB_PORT=1433
SOFTLAND_DB_USER=
SOFTLAND_DB_PASSWORD=
SOFTLAND_DB_NAME=
# SOFTLAND_DB_ENCRYPT: true en producción (Azure), false en red local
SOFTLAND_DB_ENCRYPT=false
# SOFTLAND_DB_TRUST_CERT: true solo en desarrollo/test con cert autofirmado
SOFTLAND_DB_TRUST_CERT=false
