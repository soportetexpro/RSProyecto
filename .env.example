# =====================================================
# TEXPRO RSProyecto — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitear el archivo .env real al repositorio
# =====================================================

# === BASE DE DATOS MYSQL (usuarios, configuración interna) ===
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USER=texpro_user
DB_MYSQL_PASSWORD=REEMPLAZAR_CON_PASSWORD_REAL
DB_MYSQL_DATABASE=texpro_db
DB_MYSQL_CONNECTION_LIMIT=10

# === SQL SERVER SOFTLAND (réplica facturación DTE) ===
SOFTLAND_DB_HOST=192.168.1.XX
SOFTLAND_DB_PORT=1433
SOFTLAND_DB_USER=sa
SOFTLAND_DB_PASSWORD=REEMPLAZAR_CON_PASSWORD_REAL
SOFTLAND_DB_NAME=SoftlandDB

# TLS / Cifrado SQL Server
# SOFTLAND_DB_ENCRYPT: true en producción (Azure/Softland Cloud), false en red local sin TLS
SOFTLAND_DB_ENCRYPT=true

# SEGURIDAD CRÍTICA: SOFTLAND_DB_TRUST_SERVER_CERT
#   false  → PRODUCCIÓN (obligatorio) — valida certificado del servidor SQL Server
#   true   → solo para desarrollo local con certificado autofirmado
#   Dejar en false previene ataques MITM contra la réplica Softland.
SOFTLAND_DB_TRUST_SERVER_CERT=false

# === AUTENTICACIÓN JWT ===
JWT_SECRET=GENERAR_CLAVE_ALEATORIA_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=8h

# === SERVIDOR ===
PORT=3000
NODE_ENV=development

# FRONTEND_URL: URL del frontend permitida en CORS
# OBLIGATORIO en producción — si no está definida el servidor no arranca.
# En desarrollo se puede dejar como localhost.
FRONTEND_URL=http://localhost:3001
