# =====================================================
# TEXPRO RSProyecto — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA commitear el archivo .env real al repositorio
# =====================================================

# === BASE DE DATOS MYSQL (usuarios, configuración interna) ===
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USER=texpro_user
DB_MYSQL_PASSWORD=REEMPLAZAR_CON_PASSWORD_REAL
DB_MYSQL_DATABASE=texpro_db
DB_MYSQL_CONNECTION_LIMIT=10

# === SQL SERVER SOFTLAND (réplica facturación DTE) ===
DB_SQLSERVER_HOST=192.168.1.XX
DB_SQLSERVER_PORT=1433
DB_SQLSERVER_USER=sa
DB_SQLSERVER_PASSWORD=REEMPLAZAR_CON_PASSWORD_REAL
DB_SQLSERVER_DATABASE=SoftlandDB
DB_SQLSERVER_ENCRYPT=false
DB_SQLSERVER_TRUST_SERVER_CERTIFICATE=true

# === AUTENTICACIÓN JWT ===
JWT_SECRET=GENERAR_CLAVE_ALEATORIA_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=8h

# === SERVIDOR ===
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
