# ───────────────────────────────────────────────────────────────
# RSProyecto — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real al repositorio.
# ───────────────────────────────────────────────────────────────

# Servidor
PORT=3000

# ─ MySQL (bdtexpro) ──────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=bdtexpro

# ─ JWT ─────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres
JWT_EXPIRES_IN=8h
# Generar un secret seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─ Softland Cloud (SQL Server) ───────────────────────────────
SOFTLAND_DB_HOST=
SOFTLAND_DB_PORT=1433
SOFTLAND_DB_USER=
SOFTLAND_DB_PASSWORD=
SOFTLAND_DB_NAME=
