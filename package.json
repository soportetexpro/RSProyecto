{
  "name": "rsproyecto",
  "version": "1.0.0",
  "description": "Sistema de centralización de información para Texpro",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:mysql": "jest src/config/db.test.js --runInBand --forceExit",
    "test:softland": "jest src/config/db.softland.test.js --runInBand --forceExit",
    "test:integration": "npm run test:mysql && npm run test:softland",
    "build": "node -e \"console.log('Build OK')\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.0.0"
  }
}
